
use dict_i64::*;

let d = new();

let ok1 = d.len() == 0;
let ok2 = not d.contains("foo");

d.set("rn", 1'i64);
d.set("qp", 3'i64);
d.set("cm", 2'i64);

let ok3 = d.get("rn") == 1'i64;
let ok4 = d.get("qp") == 3'i64;
let ok5 = d.get("cm") == 2'i64;
let ok6 = d.len() == 3;
let ok7 = d.contains("rn");
let ok8 = not d.contains("xyz");

// overwrite existing key; length unchanged
d.set("rn", 42'i64);
let ok9  = d.get("rn") == 42'i64;
let ok10 = d.len() == 3;

// add enough entries to trigger resize (cap 8 → 16 at 6 entries)
d.set("a", 10'i64);
d.set("b", 20'i64);
d.set("c", 30'i64);
d.set("d", 40'i64);
d.set("e", 50'i64);
let ok11 = d.len() == 8;
let ok12 = d.get("a") == 10'i64;
let ok13 = d.get("rn") == 42'i64;   // old entries survive resize
let ok14 = d.contains("e") and not d.contains("z");

return ok1 and ok2 and ok3 and ok4 and ok5 and ok6 and ok7 and ok8
	and ok9 and ok10 and ok11 and ok12 and ok13 and ok14;
