// Simpson's 3/8 rule numerical integrator, taking the integrand as a fn
// callback and forwarding it through a generic Newton-Cotes engine.
//
// Ported from simpson_38_integrator() / newton_cotes_integrator() in
// numerical-analysis's src/integrate.F90, and the corresponding tests in
// test/chapter_3.F90 (chapter_3_newton_cotes)
//
//     https://github.com/JeffIrwin/numerical-analysis/blob/main/src/integrate.F90

use integrate;

fn sin_fn(x: f64): f64
{
	// The intrinsic `sin` can't be pointed to directly (E87), so it needs a
	// user-defined wrapper to be used as a callback
	return sin(x);
}

fn assert_close(a: f64, b: f64, tol: f64): i32
{
	if abs(a - b) < tol
		return 0;
	return 1;
}

fn main(): i32
{
	let status = 0;

	let area1 = integrate::simpson_38(sin_fn, 0.0, std::PI, std::PI);
	//println("area1 = ", area1);
	status += assert_close(area1, 2.04052428, 1.0e-6);

	let area2 = integrate::simpson_38(sin_fn, 0.0, std::PI, 0.1);
	//println("area2 = ", area2);
	status += assert_close(area2, 2.0000000325630984, 1.0e-12);

	return status;
}

return main();

