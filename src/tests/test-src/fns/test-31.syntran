// Simpson's 3/8 rule, adaptive Simpson, and adaptive Gauss-Kronrod (7-15)
// numerical integrators, taking the integrand as a fn callback and
// forwarding it through a generic Newton-Cotes engine (or, for the adaptive
// cases, a recursive refinement).
//
// Ported from simpson_38_integrator() / newton_cotes_integrator() /
// simpson_adaptive_integrator() / gk15_adaptive_integrator() /
// gk15_integrator_params() in numerical-analysis's src/integrate.F90, and the
// corresponding tests in test/chapter_3.F90 (chapter_3_newton_cotes,
// chapter_3_adaptive)
//
//     https://github.com/JeffIrwin/numerical-analysis/blob/main/src/integrate.F90

use integrate;

fn sin_fn(x: f64): f64
{
	// The intrinsic `sin` can't be pointed to directly (E87), so it needs a
	// user-defined wrapper to be used as a callback
	return sin(x);
}

fn sqrt_fn(x: f64): f64
{
	return sqrt(x);
}

fn log_fn(x: f64): f64
{
	return log(x);
}

fn bessel_3(tau: f64, params: [f64; :]): f64
{
	// Integral representation of the Bessel function of the first kind,
	// order n = 3.  `params[0]` is x in J_3(x); `params` lets one callback
	// cover the whole family of x values instead of a fn per x
	return 1.0 / std::PI * cos(3 * tau - params[0] * sin(tau));
}

fn assert_close(a: f64, b: f64, tol: f64): i32
{
	if abs(a - b) < tol
		return 0;
	return 1;
}

fn main(): i32
{
	let status = 0;

	let area1 = integrate::simpson_38(sin_fn, 0.0, std::PI, std::PI);
	//println("area1 = ", area1);
	status += assert_close(area1, 2.04052428, 1.0e-6);

	let area2 = integrate::simpson_38(sin_fn, 0.0, std::PI, 0.1);
	//println("area2 = ", area2);
	status += assert_close(area2, 2.0000000325630984, 1.0e-12);

	let area3 = integrate::simpson_adaptive(sin_fn, 0.0, std::PI, 1.0e-10);
	//println("area3 = ", area3);
	status += assert_close(area3, 1.999999999999999, 1.0e-9);

	let area4 = integrate::simpson_adaptive(sqrt_fn, 0.0, 1.0, 1.0e-10);
	//println("area4 = ", area4);
	status += assert_close(area4, 6.666666661354972E-01, 1.e-9);

	// log() is singular at x = 0, so xmin is offset slightly and tol is
	// relaxed, mirroring the upstream test
	let area5 = integrate::simpson_adaptive(log_fn, 1.0e-10, 1.0, 1.0e-2);
	//println("area5 = ", area5);
	status += assert_close(area5, -1.000015864472923E+00, 1.e-9);

	let area6 = integrate::gk15_adaptive(sin_fn, 0.0, std::PI, 1.0e-10);
	//println("area6 = ", area6);
	status += assert_close(area6, 2.0, 1.0e-9);

	let area7 = integrate::gk15_adaptive(sqrt_fn, 0.0, 1.0, 1.0e-10);
	//println("area7 = ", area7);
	status += assert_close(area7, 6.666666666674688E-01, 1.0e-9);

	// Gauss-Kronrod abscissas are always interior, so unlike
	// simpson_adaptive() this can integrate log() starting right at the
	// singularity at xmin = 0
	let area8 = integrate::gk15_adaptive(log_fn, 0.0, 1.0, 1.0e-10);
	//println("area8 = ", area8);
	status += assert_close(area8, -9.999999741718582E-01, 1.0e-9);

	// J_3(2.5) and J_3(2.8), the Bessel function of the first kind, computed
	// via its integral representation with a runtime params array
	let area9 = integrate::gk15_integrator_params(bessel_3, [2.5], 0.0, std::PI, 1.0e-10);
	//println("area9 = ", area9);
	status += assert_close(area9, 0.21660039103911352, 1.0e-10);

	let area10 = integrate::gk15_integrator_params(bessel_3, [2.8], 0.0, std::PI, 1.0e-10);
	//println("area10 = ", area10);
	status += assert_close(area10, 0.2726986037216204, 1.0e-10);

	return status;
}

return main();

