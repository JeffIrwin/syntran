// Numerical integration module
//
// Ported from numerical-analysis's src/integrate.F90:
//
//     https://github.com/JeffIrwin/numerical-analysis/blob/main/src/integrate.F90

fn newton_cotes(f: fn(f64): f64, xmin: f64, xmax: f64, dx: f64, coefs: [f64; :]): f64
{
	// Integrate fn `f` from xmin to xmax with step size dx using given
	// Newton-Cotes coefficients `coefs`

	let nc = i32(size(coefs, 0));
	let n  = max(1, i32((xmax - xmin) / dx));
	let dxl = (xmax - xmin) / n;

	let area = 0.0;
	let j0 = 0;
	let f0 = 0.0;
	for i in [0: n]
	{
		let darea = 0.0;
		if j0 > 0
			darea = coefs[nc - 1] * f0;
		for j in [j0: nc]
		{
			let x = xmin + i * (xmax - xmin) / n + j * dxl / (nc - 1);
			f0 = f(x);
			darea = darea + coefs[j] * f0;
		}
		area = area + darea;

		// Start point of next subinterval is the end point of this one
		j0 = 1;
	}

	area = area * dxl / sum(coefs);
	return area;
}

fn simpson_38(f: fn(f64): f64, xmin: f64, xmax: f64, dx: f64): f64
{
	// Integrate fn `f` from xmin to xmax with step size dx using Simpson's
	// 3/8 rule.  The callback `f` is forwarded through to newton_cotes()

	let coefs = [1.0, 3.0, 3.0, 1.0];
	return newton_cotes(f, xmin, xmax, dx, coefs);
}

// Maximum recursion depth for the adaptive Simpson integrator
const MAX_LEVELS = 16;

fn simpson_adapt_aux(f: fn(f64): f64, a: f64, b: f64, eps: f64, whole: f64,
	fa: f64, fb: f64, fm: f64, rec: i32): f64
{
	// Recursive core of the adaptive Simpson integrator.  Not for end users --
	// see simpson_adaptive() below
	//
	// Source: https://en.wikipedia.org/wiki/Adaptive_Simpson%27s_method

	let m  = 0.5 * (a + b);
	let h  = 0.5 * (b - a);
	let lm = 0.5 * (a + m);
	let rm = 0.5 * (m + b);

	// Floating-point tolerance or interval underflow: accept current estimate
	if eps / 2 == eps or a == lm
		return whole;

	let flm = f(lm);
	let frm = f(rm);
	let left  = h / 6 * (fa + 4 * flm + fm);
	let right = h / 6 * (fm + 4 * frm + fb);
	let delta = left + right - whole;

	if rec <= 0 or abs(delta) <= 15 * eps
		return left + right + delta / 15.0;

	return
		simpson_adapt_aux(f, a, m, eps / 2, left,  fa, fm, flm, rec - 1) +
		simpson_adapt_aux(f, m, b, eps / 2, right, fm, fb, frm, rec - 1);
}

fn simpson_adaptive(f: fn(f64): f64, xmin: f64, xmax: f64, tol: f64): f64
{
	// Integrate fn `f` from xmin to xmax using the adaptive Simpson method.
	// `tol` is the target error.  Recursion depth is capped at MAX_LEVELS
	let h  = xmax - xmin;
	let fa = f(xmin);
	let fm = f(0.5 * (xmin + xmax));
	let fb = f(xmax);
	let whole = h / 6 * (fa + 4 * fm + fb);

	return simpson_adapt_aux(f, xmin, xmax, tol, whole, fa, fb, fm, MAX_LEVELS);
}

// Gauss-Kronrod 7-15 abscissas and weights, taken from Jacob Williams'
// quadpack (BSD-3 license):
//
//     https://github.com/jacobwilliams/quadpack/blob/702abfd5f0acbdb51439695334347a4b3c0dc87a/src/quadpack_generic.F90#L5209
//
// The first NG_GK15 entries are the shared Gauss/Kronrod abscissas; XK_GK15
// holds all NK_GK15 Kronrod abscissas, and WG_GK15 only has weights for the
// first NG_GK15 (Gauss) abscissas
const NG_GK15 = 7;
const NK_GK15 = 15;

const XK_GK15 = [
	 0.949107912342758524526189684047851262401,
	-0.949107912342758524526189684047851262401,
	 0.741531185599394439863864773280788407074,
	-0.741531185599394439863864773280788407074,
	 0.405845151377397166906606412076961463347,
	-0.405845151377397166906606412076961463347,
	 0.0,
	 0.991455371120812639206854697526328516642,
	-0.991455371120812639206854697526328516642,
	 0.864864423359769072789712788640926201211,
	-0.864864423359769072789712788640926201211,
	 0.586087235467691130294144838258729598437,
	-0.586087235467691130294144838258729598437,
	 0.207784955007898467600689403773244913480,
	-0.207784955007898467600689403773244913480
];

const WG_GK15 = [
	0.129484966168869693270611432679082018329,
	0.129484966168869693270611432679082018329,
	0.279705391489276667901467771423779582487,
	0.279705391489276667901467771423779582487,
	0.381830050505118944950369775488975133878,
	0.381830050505118944950369775488975133878,
	0.417959183673469387755102040816326530612
];

const WK_GK15 = [
	0.0630920926299785532907006631892042866651,
	0.0630920926299785532907006631892042866651,
	0.140653259715525918745189590510237920400,
	0.140653259715525918745189590510237920400,
	0.190350578064785409913256402421013682826,
	0.190350578064785409913256402421013682826,
	0.209482141084727828012999174891714263698,
	0.0229353220105292249637320080589695919936,
	0.0229353220105292249637320080589695919936,
	0.104790010322250183839876322541518017444,
	0.104790010322250183839876322541518017444,
	0.169004726639267902826583426598550284106,
	0.169004726639267902826583426598550284106,
	0.204432940075298892414161999234649084717,
	0.204432940075298892414161999234649084717
];

fn gk15_aux(f: fn(f64): f64, xmin: f64, xmax: f64, tol: f64, whole: f64, rec: i32): f64
{
	// Recursive core of the adaptive Gauss-Kronrod integrator.  Not for end
	// users -- see gk15_adaptive() below

	let dx2 = 0.5 * (xmax - xmin);
	let mid = 0.5 * (xmin + xmax);

	// Floating-point tolerance or interval underflow: accept current estimate
	if tol / 2 == tol or xmin == mid
		return whole;

	let areag = 0.0;
	let areak = 0.0;
	for i in [0: NG_GK15]
	{
		let fx = f(mid + XK_GK15[i] * dx2);
		areag = areag + WG_GK15[i] * fx;
		areak = areak + WK_GK15[i] * fx;
	}
	for i in [NG_GK15: NK_GK15]
	{
		let fx = f(mid + XK_GK15[i] * dx2);
		areak = areak + WK_GK15[i] * fx;
	}
	areag = areag * dx2;
	areak = areak * dx2;

	let diff = abs(areak - areag);
	if diff < tol or rec <= 0
		return areak;

	return
		gk15_aux(f, xmin, mid, tol / 2, areak / 2, rec - 1) +
		gk15_aux(f, mid, xmax, tol / 2, areak / 2, rec - 1);
}

fn gk15_adaptive(f: fn(f64): f64, xmin: f64, xmax: f64, tol: f64): f64
{
	// Integrate fn `f` from xmin to xmax using the adaptive Gauss-Kronrod
	// (7-point Gauss, 15-point Kronrod) method.  Unlike simpson_adaptive(),
	// Gauss/Kronrod abscissas are always interior, so `f` is never evaluated
	// at xmin or xmax -- useful for integrable singularities at the endpoints.
	// Recursion depth is capped at MAX_LEVELS

	return gk15_aux(f, xmin, xmax, tol, 0.0, MAX_LEVELS);
}

fn gk15_auxp(f: fn(f64, [f64; :]): f64, params: [f64; :], xmin: f64, xmax: f64,
	tol: f64, whole: f64, rec: i32): f64
{
	// Recursive core of the adaptive Gauss-Kronrod integrator with params.
	// Not for end users -- see gk15_integrator_params() below

	let dx2 = 0.5 * (xmax - xmin);
	let mid = 0.5 * (xmin + xmax);

	// Floating-point tolerance or interval underflow: accept current estimate
	if tol / 2 == tol or xmin == mid
		return whole;

	let areag = 0.0;
	let areak = 0.0;
	for i in [0: NG_GK15]
	{
		let fx = f(mid + XK_GK15[i] * dx2, params);
		areag = areag + WG_GK15[i] * fx;
		areak = areak + WK_GK15[i] * fx;
	}
	for i in [NG_GK15: NK_GK15]
	{
		let fx = f(mid + XK_GK15[i] * dx2, params);
		areak = areak + WK_GK15[i] * fx;
	}
	areag = areag * dx2;
	areak = areak * dx2;

	let diff = abs(areak - areag);
	if diff < tol or rec <= 0
		return areak;

	return
		gk15_auxp(f, params, xmin, mid, tol / 2, areak / 2, rec - 1) +
		gk15_auxp(f, params, mid, xmax, tol / 2, areak / 2, rec - 1);
}

fn gk15_integrator_params(f: fn(f64, [f64; :]): f64, params: [f64; :], xmin: f64,
	xmax: f64, tol: f64): f64
{
	// Integrate fn `f` from xmin to xmax using the adaptive Gauss-Kronrod
	// (7-point Gauss, 15-point Kronrod) method, like gk15_adaptive() above,
	// but `f` also takes a `params` array.  This lets one callback represent
	// a whole family of integrands parametrized by e.g. a runtime constant,
	// instead of writing a new fn for each parameter value.  Recursion depth
	// is capped at MAX_LEVELS

	return gk15_auxp(f, params, xmin, xmax, tol, 0.0, MAX_LEVELS);
}
