// Same call site alternately dispatching to fn-pointer targets with
// different numbers of locals, to exercise the VM's per-frame-depth locals
// pool resize logic (see OP_CALL_PTR in vm_exec.f90)

fn small(n: i32): i32
{
	return n + 1;
}

fn big(n: i32): i32
{
	let a = n + 1;
	let b = a + 1;
	let c = b + 1;
	let d = c + 1;
	let e = d + 1;
	return e;
}

fn apply(f: fn(i32): i32, x: i32): i32
{
	return f(x);
}

let total = 0;
for i in [0: 4]
{
	total = total + apply(small, i);
	total = total + apply(big, i);
}

// i=0: small=1,big=5 | i=1: small=2,big=6 | i=2: small=3,big=7 | i=3: small=4,big=8
// sum = (1+5)+(2+6)+(3+7)+(4+8) = 6+8+10+12 = 36
return total;
