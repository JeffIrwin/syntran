//==============================================================================
//
// This is a poople solver
//
// Poople is a word game with some similarities to wordle:
//
//     https://poople.io/
//
// Given a starting 4 letter word, the goal is to transform that word into
// "POOP" one by changing one letter at a time, with each intermediate 4 letter
// word being a real word
//
// For example:
//
// TEAR
// BEAR
// BOAR
// BOOR
// POOR
// POOP
//
//==============================================================================

use dict_i64::*;
use dict_str::*;

let N  =  4;  // 4 letter words
let NA = 26;  // alphabet size

let POOP = "poop";  // goal word. use lowercase internally, uppercase for output

// Ignore these words from the system dictionary
let BLOCKLIST = [
	//"ARES",  // not sure if this is valid per poople but i suspect it isn't
	//"ORCS",
	""
];

fn poople_solve(dict: &dict_i64, init_word_cased: str): [str; :]
{
	let init_word = to_lower(init_word_cased);
	if len(init_word) != N
	{
		println("Error: given initial word `", to_upper(init_word), "' is not 4 letters long");
		println();
		exit(2);
	}

	// BFS (breadth-first search)
	let QCAP = 1024 * 64;
	let q = [""; QCAP];
	let qs = 0;  let qe = 0;

	// Push
	q[qe] = init_word;  qe += 1;

	let prev = new_dict_str();

	while qs != qe
	{
		// Pop
		let u = q[qs];  qs = (qs+1) % QCAP;
		if (u == POOP) break;

		// Search neighboring words, i.e. those that differ from `u` by one
		// letter
		for ii in [0: N]
		for ia in [0: NA]
		{
			let v = u;
			v[ii] = char(i32("a") + ia);
			if (v == u) continue;
			if (get_dict_i64(&dict, v) != 1'i64) continue;
			if (get_dict_str(&prev, v) != ""   ) continue;
			set_dict_str(&prev, v, u);

			// Push
			q[qe] = v;  qe = (qe+1) % QCAP;
			if qe == qs
			{
				println("Error: queue overflow!");
				exit(3);
			}
		}
	}

	// TODO: check what happens with an unreachable state, e.g. starting with
	// some crazy non-word like "zzzz". I think above loop will exhaust queue
	// and exit, then next loop will return an empty array

	// End BFS. Now backtrack from poop via previous linked words
	let word = POOP;
	let n = 0;
	while true
	{
		q[n] = word;
		n += 1;
		word = get_dict_str(&prev, word);
		if (word == init_word) break;
		if (word == "") break;
	}
	q[n] = word;
	n += 1;

	return q[n-1: -1: -1];
}

fn log_poople_steps(steps: &[str; :])
{
	println("steps = ");
	for step in steps
		println("    ", to_upper(step));
	println();
	return;
}

fn setup_dict(dict_filename: str, blocklist: &dict_i64): dict_i64
{
	// Load a dictionary of valid words. Only save 4-letter ones
	let dict = new_dict_i64();
	let n = 0;

	// sudo apt install wamerican
	//
	// TODO: harden against file not existing. Add helpful error about how to
	// install
	let fdict = open(dict_filename, "r");
	//let fdict = open("/usr/share/dict/american-english", "r");

	while not eof(fdict)
	{
		let line = readln(fdict);
		if len(line) != N continue;
		let is_lower = true;
		for c in line
		{
			is_lower = is_lower(c);
			if (not is_lower) break;
		}
		if (not is_lower) continue;
		if (get_dict_i64(&blocklist, line) == 1'i64) continue;

		set_dict_i64(&dict, line, 1'i64);
		n += 1;
	}
	return dict;
}

fn setup_blocklist(): dict_i64
{
	// Initialize a blocklist dictionary from the global BLOCKLIST array
	let blocklist = new_dict_i64();
	for word in BLOCKLIST
		set_dict_i64(&blocklist, to_lower(word), 1'i64);
	return blocklist;
}

fn is_lower(char_: str): bool
{
	return i32("a") <= i32(char_) and i32(char_) <= i32("z");
}
fn is_upper(char_: str): bool
{
	return i32("A") <= i32(char_) and i32(char_) <= i32("Z");
}
fn to_lower(word: str): str
{
	let upper = word;
	for i in [0: len(word)]
	{
		if not is_upper(word[i]) continue;
		upper[i] = char(i32(word[i]) + i32("a") - i32("A"));
	}
	return upper;
}
fn to_upper(word: str): str
{
	let upper = word;
	for i in [0: len(word)]
	{
		if not is_lower(word[i]) continue;
		upper[i] = char(i32(word[i]) + i32("A") - i32("a"));
	}
	return upper;
}

